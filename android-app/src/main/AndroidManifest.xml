<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Audio recording permission for real-time audio processing -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    
    <!-- Audio playback permission -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    
    <!-- Wake lock for continuous audio processing -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- Foreground service permission for background audio processing -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    
    <!-- Storage permissions for audio file I/O -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" 
        android:maxSdkVersion="28" />
    
    <!-- Network permissions for plugin downloads and updates -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Boot permission for auto-start functionality -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- Low-latency audio feature for professional audio processing -->
    <uses-feature
        android:name="android.hardware.audio.low_latency"
        android:required="true" />
    
    <!-- Professional audio feature for high-quality processing -->
    <uses-feature
        android:name="android.hardware.audio.pro"
        android:required="false" />

    <!-- MIDI support for external controllers -->
    <uses-feature
        android:name="android.software.midi"
        android:required="false" />
    
    <!-- Microphone requirement -->
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <application
        android:name=".LSPAudioApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:label="LSP Audio Processor"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:theme="@style/Theme.LSPAudioProcessor"
        tools:targetApi="31">

        <!-- Main audio processing activity -->
        <activity
            android:name="com.example.lspandroid.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Native library metadata -->
        <meta-data
            android:name="android.app.lib_name"
            android:value="lsp_audio_engine" />

    </application>

</manifest>
